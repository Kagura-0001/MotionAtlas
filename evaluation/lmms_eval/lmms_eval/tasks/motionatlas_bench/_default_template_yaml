dataset_path: maxLWSv2/motionatlas-bench
dataset_kwargs:
  token: True
test_split: test
output_type: generate_until
doc_to_visual: !function utils.motionatlas_doc_to_visual
doc_to_text: !function utils.motionatlas_doc_to_text
doc_to_messages: !function utils.motionatlas_doc_to_messages
doc_to_target: "caption_target"
generation_kwargs:
  max_new_tokens: 1024
  temperature: 0
  top_p: 1.0
  num_beams: 1
  do_sample: false
process_results: !function utils.motionatlas_process_results
metric_list:
  - metric: motionatlas_weighted_score
    aggregation: !function utils.motionatlas_aggregate_weighted_score
    higher_is_better: true
  - metric: motionatlas_accuracy
    aggregation: !function utils.motionatlas_aggregate_accuracy
    higher_is_better: true
  - metric: motionatlas_recall
    aggregation: !function utils.motionatlas_aggregate_recall
    higher_is_better: true
  - metric: motionatlas_precision
    aggregation: !function utils.motionatlas_aggregate_precision
    higher_is_better: true
  - metric: motionatlas_answered_rate
    aggregation: !function utils.motionatlas_aggregate_answered_rate
    higher_is_better: true
lmms_eval_specific_kwargs:
  default:
    setting: first_mask
    num_frames: 16
    outline_thickness: 3
metadata:
  version: 0.1
  description: "MotionAtlas-Bench caption-to-Gemini-judge evaluation."
